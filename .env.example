# ─── 数据库 ───
# 生产（Vercel / Serverless）必须使用 Supabase Transaction Pooler（pgBouncer）
# 注意：Prisma 在 pgBouncer transaction 模式下必须带 `?pgbouncer=true`
DATABASE_URL="postgresql://<user>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma 迁移/生成迁移时必须使用 Direct connection（不要用 pooler）
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Prisma migrate dev 需要 shadow database，用同一个 DB 的独立 schema 即可（无需创建新数据库）
SHADOW_DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?schema=shadow"

# ─── NextAuth ───
AUTH_SECRET="请替换为至少32位随机字符串"
NEXTAUTH_URL="https://<你的生产域名>"

# ─── Supabase Storage（头像上传）───
# Supabase Dashboard → Settings → API
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service_role_key>"

# ─── AI 视觉识别（通义千问-VL，免费 1M tokens/月）───
# 申请地址：https://dashscope.aliyun.com → 开通 DashScope → 创建 API Key
DASHSCOPE_API_KEY=""
