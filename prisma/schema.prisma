generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  // Vercel / serverless runtime: MUST use Supabase Transaction Pooler (pgBouncer)
  // Example: postgresql://...@*.pooler.supabase.com:6543/postgres?pgbouncer=true
  url               = env("DATABASE_URL")
  // Direct connection is required for Prisma migrations (avoid pooler limitations).
  directUrl         = env("DIRECT_URL")
  // Shadow database URL for migration diffing (use a dedicated schema, not a new database).
  // Example: DIRECT_URL + ?schema=shadow
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Exercise {
  id             String        @id @default(cuid())
  name           String        @unique
  muscleGroup    String
  category       String
  description    String?
  instructions   String?
  equipment      String?
  difficulty     String?
  tips           String?
  commonMistakes String?
  userId         String?
  isCustom       Boolean       @default(false)
  createdAt      DateTime      @default(now())
  alias          String?
  User           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutSets    WorkoutSet[]

  @@index([name])
  @@index([muscleGroup])
  @@index([userId])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  workoutId String
  type      String   @default("summary")
  content   String
  createdAt DateTime @default(now())
  Workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlanDay {
  id           String       @id @default(cuid())
  planId       String
  dayIndex     Int
  dayName      String
  exercises    String
  createdAt    DateTime     @default(now())
  TrainingPlan TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model TrainingPlan {
  id        String    @id @default(cuid())
  userId    String
  name      String
  goal      String
  frequency Int
  level     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  days      PlanDay[]
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String?
  password     String
  age          Int?
  gender       String?
  location     String?
  bio          String?
  avatar       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  Exercise     Exercise[]
  Feedback     Feedback[]
  TrainingPlan TrainingPlan[]
  Workout      Workout[]
  Food         Food[]
  FoodLog      FoodLog[]
  MealPlan     MealPlan[]
  CarbCycle    CarbCycle[]
  BodyData     BodyData[]
  WaterLog     WaterLog[]
  UserSettings UserSettings?
}

model Workout {
  id          String       @id @default(cuid())
  userId      String
  date        DateTime
  duration    Int?
  notes       String?
  metadata    String?      // JSON: AI-parsed structured data for free/cardio records
  totalVolume Float
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  Feedback    Feedback[]
  User        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutSets WorkoutSet[]

  @@index([userId, date])
}

model WorkoutSet {
  id          String    @id @default(cuid())
  workoutId   String
  exercise    String    // 动作名称（deprecated → 迁移后用 exerciseId）
  exerciseId  String?   // FK → Exercise.id
  muscleGroup String?
  type        String
  setNumber   Int
  weight      Float
  reps        Int
  rir         Int?
  isFailure   Boolean   @default(false)
  isPR        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  workout     Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseRel Exercise? @relation(fields: [exerciseId], references: [id])

  @@index([exercise])
  @@index([exerciseId])
  @@index([muscleGroup])
  @@index([workoutId])
}

model Food {
  id          String    @id @default(cuid())
  name        String
  nameEn      String?
  brand       String?
  barcode     String?   @unique
  category    String?
  servingUnit String    @default("g")
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  sugar       Float?
  sodium      Float?
  source      String    @default("custom")
  isCustom    Boolean   @default(false)
  userId      String?
  createdAt   DateTime  @default(now())
  foodLogs    FoodLog[]
  User        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([barcode])
  @@index([userId])
  @@index([category])
}

model FoodLog {
  id        String    @id @default(cuid())
  userId    String
  foodId    String
  mealType  String    @default("other")
  serving   Float
  servingG  Float
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  date      DateTime
  createdAt DateTime  @default(now())
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  food      Food      @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([foodId])
}

model MealPlan {
  id        String        @id @default(cuid())
  userId    String
  name      String
  goal      String
  dailyCal  Float
  proteinP  Float
  carbsP    Float
  fatP      Float
  isActive  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  days      MealPlanDay[]
  carbCycles CarbCycle[]
  User      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([goal])
}

model MealPlanDay {
  id             String   @id @default(cuid())
  planId         String
  dayIndex       Int
  dayLabel       String
  targetCal      Float
  targetProtein  Float
  targetCarbs    Float
  targetFat      Float
  meals          String
  createdAt      DateTime @default(now())
  plan           MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model CarbCycle {
  id         String   @id @default(cuid())
  userId     String
  planId     String
  dayOfWeek  Int
  cycleType  String
  carbFactor Float
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       MealPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
  @@index([planId])
}

model BodyData {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weight    Float?
  bodyFat   Float?
  chest     Float?
  waist     Float?
  hip       Float?
  armLeft   Float?
  armRight  Float?
  thighLeft Float?
  thighRight Float?
  neck      Float?
  notes     String?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  date      DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model UserSettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  height         Float?
  tdee           Float?
  activity       String?
  goal           String?
  waterGoal      Int      @default(2500)
  targetCalories Float?  @default(2000)
  targetProtein  Float?  @default(60)
  targetCarbs    Float?  @default(250)
  targetFat      Float?  @default(65)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
