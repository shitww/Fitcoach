{
  "name": "fitcoach-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "FitCoach 微信小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true
  },
  "scripts": {
    "dev:weapp": "npm run build:weapp -- --watch",
    "build:weapp": "taro build --type weapp",
    "dev:swan": "npm run build:swan -- --watch",
    "build:swan": "taro build --type swan",
    "dev:alipay": "npm run build:alipay -- --watch",
    "build:alipay": "taro build --type alipay",
    "dev:tt": "npm run build:tt -- --watch",
    "build:tt": "taro build --type tt",
    "dev:h5": "npm run build:h5 -- --watch",
    "build:h5": "taro build --type h5",
    "dev:rn": "npm run build:rn -- --watch",
    "build:rn": "taro build --type rn",
    "dev:qq": "npm run build:qq -- --watch",
    "build:qq": "taro build --type qq",
    "dev:jd": "npm run build:jd -- --watch",
    "build:jd": "taro build --type jd",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx --ignore-pattern dist"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.4",
    "iOS >= 8"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime-corejs3": "^7.7.7",
    "@nutui/nutui-react-taro": "^2.3.4",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-alipay": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-jd": "4.2.0",
    "@tarojs/plugin-platform-qq": "4.2.0",
    "@tarojs/plugin-platform-swan": "4.2.0",
    "@tarojs/plugin-platform-tt": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/plugin-proposal-class-properties": "^7.8.3",
    "@babel/plugin-proposal-decorators": "^7.8.3",
    "@babel/plugin-transform-react-jsx": "^7.14.9",
    "@babel/plugin-transform-runtime": "^7.7.6",
    "@babel/preset-env": "^7.7.6",
    "@babel/preset-react": "^7.7.4",
    "@babel/preset-typescript": "^7.7.4",
    "@tarojs/cli": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/webpack-env": "^1.13.6",
    "@typescript-eslint/eslint-plugin": "^5.20.0",
    "@typescript-eslint/parser": "^5.20.0",
    "babel-preset-taro": "4.2.0",
    "eslint": "^8.12.0",
    "eslint-config-taro": "4.2.0",
    "eslint-plugin-react": "^7.8.2",
    "eslint-plugin-react-hooks": "^4.2.0",
    "eslint-plugin-react-refresh": "^0.3.0",
    "eslint-plugin-import": "^2.12.0",
    "eslint-plugin-taro": "4.2.0",
    "typescript": "~4.1.0",
    "webpack": "^5.89.0"
  }
